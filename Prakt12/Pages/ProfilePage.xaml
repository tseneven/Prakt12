<Page x:Class="Prakt12.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Prakt12.Pages"
      mc:Ignorable="d" 
      xmlns:materialDesign ="http://materialdesigninxaml.net/winfx/xaml/themes"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage" Initialized="Page_Initialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>

        </Grid.RowDefinitions>
        <TextBlock FontSize="20" HorizontalAlignment="Center">Ваш профиль</TextBlock>
        <StackPanel Margin="10"  Orientation="Vertical" Grid.Row="1">
            <TextBox x:Name="PhoneTextBox" AutomationProperties.Name="Phone" Text="{Binding Phone}"  materialDesign:HintAssist.Hint="Телефон"/>
        </StackPanel>
        <StackPanel Margin="10"  Orientation="Vertical" Grid.Row="2">
            <TextBox x:Name="BioTextBox" AutomationProperties.Name="dis" Text="{Binding Bio}"  materialDesign:HintAssist.Hint="Описание"/>
        </StackPanel>
        <StackPanel Margin="10"  Orientation="Vertical" Grid.Row="3">
            <DatePicker x:Name="DatePickerDate"  materialDesign:HintAssist.Hint="Дата рождения" DisplayDateStart ="01/01/1890" SelectedDate="{Binding Birthday, Mode=TwoWay  }"></DatePicker>
        </StackPanel>
        <StackPanel HorizontalAlignment="Center" Grid.Row="4" Orientation="Horizontal">
            <Button HorizontalAlignment="Center" Margin="10 0" Click="Button_Click">Назад</Button>
            <Button x:Name="editBtn" HorizontalAlignment="Center" Margin="10 0" Click="Button_Click_1">Редактировать</Button>
        </StackPanel>
    </Grid>
</Page>
