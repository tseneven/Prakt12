<Page x:Class="Prakt12.Pages.ListUserRoles"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Prakt12.Pages"
      mc:Ignorable="d" 
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListUserRoles">

    <Grid Background="White">
        <StackPanel Margin="10">
            <Button HorizontalAlignment="Left" Click="Button_Click">Назад</Button>
            <ListView Background="Black" ItemsSource="{Binding service.usersList}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Vertical">
                                <TextBlock>Логин</TextBlock>
                                <TextBlock Text="{Binding Login}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <TextBlock>Имя</TextBlock>
                                <TextBlock Text="{Binding Name}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <TextBlock>Почта</TextBlock>
                                <TextBlock Text="{Binding Email}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <TextBlock>Запись создана</TextBlock>
                                <TextBlock Text="{Binding CreatedAt}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <TextBlock>Роль</TextBlock>
                                <TextBlock Text="{Binding Role.Title}"></TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
