<Page x:Class="Prakt12.Pages.RoleUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Prakt12.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      Title="RoleUsers">

    <Grid Background="White">
        <StackPanel Margin="10">

            <GroupBox Header="Пользователи" Margin="5">
                <ListView Background="Black" ItemsSource="{Binding service.usersList}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Логин</TextBlock>
                                    <TextBlock Text="{Binding Login}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Имя</TextBlock>
                                    <TextBlock Text="{Binding Name}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Почта</TextBlock>
                                    <TextBlock Text="{Binding Email}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Запись создана</TextBlock>
                                    <TextBlock Text="{Binding CreatedAt}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Роль</TextBlock>
                                    <TextBlock Text="{Binding Role.Title}"></TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>

            <GroupBox Header="Менеджеры" Margin="5">
                <ListView Background="Black" ItemsSource="{Binding service.menegersList}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Логин</TextBlock>
                                    <TextBlock Text="{Binding Login}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Имя</TextBlock>
                                    <TextBlock Text="{Binding Name}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Почта</TextBlock>
                                    <TextBlock Text="{Binding Email}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Запись создана</TextBlock>
                                    <TextBlock Text="{Binding CreatedAt}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Роль</TextBlock>
                                    <TextBlock Text="{Binding Role.Title}"></TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>

            <GroupBox Header="Администраторы" Margin="5">
                <ListView Background="Black" ItemsSource="{Binding service.adminsList}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Логин</TextBlock>
                                    <TextBlock Text="{Binding Login}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Имя</TextBlock>
                                    <TextBlock Text="{Binding Name}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Почта</TextBlock>
                                    <TextBlock Text="{Binding Email}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Запись создана</TextBlock>
                                    <TextBlock Text="{Binding CreatedAt}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock>Роль</TextBlock>
                                    <TextBlock Text="{Binding Role.Title}"></TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>

        </StackPanel>
    </Grid>
</Page>
