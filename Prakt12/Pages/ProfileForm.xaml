<Page x:Class="Prakt12.Pages.ProfileForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Prakt12.Pages"
      mc:Ignorable="d" 
      xmlns:materialDesign ="http://materialdesigninxaml.net/winfx/xaml/themes"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfileForm">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            
        </Grid.RowDefinitions>
        <TextBlock FontSize="20" HorizontalAlignment="Center">Добавить профиль</TextBlock>
        <StackPanel Margin="10"  Orientation="Vertical" Grid.Row="1">
            <TextBox AutomationProperties.Name="Phone" Text="{Binding Phone}" materialDesign:HintAssist.Hint="Телефон"/>
        </StackPanel>
        <StackPanel Margin="10"  Orientation="Vertical" Grid.Row="2">
            <TextBox AutomationProperties.Name="dis" Text="{Binding Bio}"  materialDesign:HintAssist.Hint="Описание"/>
        </StackPanel>
        <StackPanel Margin="10"  Orientation="Vertical" Grid.Row="3">
            <DatePicker materialDesign:HintAssist.Hint="Дата рождения" DisplayDateStart ="01/01/1890" SelectedDate="{Binding Birthday, Mode=TwoWay  }"></DatePicker>
        </StackPanel>
        <Button HorizontalAlignment="Center" Margin="10 0" Click="Button_Click" Grid.Row="4">Добавить</Button>

    </Grid>
</Page>
